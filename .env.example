# Server configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection (use container name or localhost)
MONGO_URI=mongodb://db_user_whisper:SuperSecurePassword2026!@localhost:27017/campuswhisper?authSource=admin

# Cryptographic Keys (Must be strong and kept private)
# SESSION_SECRET should be a cryptographically secure random string
SESSION_SECRET=your_session_secret_change_me_in_production_12345

# ENCRYPTION_KEY must be a 32-byte hex string (64 characters) for AES-256-GCM
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
